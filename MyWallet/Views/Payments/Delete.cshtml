@model MyWallet.Models.Payment

@{
    ViewData["Title"] = "Delete Payment";
}

<h1>Delete Payment</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Payment</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Posted</dt>
        <dd class="col-sm-10">@Model.Posted.ToShortDateString()</dd>

        <dt class="col-sm-2">Item</dt>
        <dd class="col-sm-10">@Model.ItemName</dd>

        <dt class="col-sm-2">Payee</dt>
        <dd class="col-sm-10">@Model.PaymentName</dd>

        <dt class="col-sm-2">Amount</dt>
        <dd class="col-sm-10">@String.Format("{0:C}", Model.Amount)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="PaymentId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
