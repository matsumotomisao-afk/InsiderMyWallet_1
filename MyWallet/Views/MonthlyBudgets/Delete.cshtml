@model MyWallet.Models.MonthlyBudget

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>MonthlyBudget</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Year</dt>
        <dd class="col-sm-10">@Model.YearNum</dd>

        <dt class="col-sm-2">Month</dt>
        <dd class="col-sm-10">@Model.MonthNum</dd>

        <dt class="col-sm-2">Budget</dt>
        <dd class="col-sm-10">@String.Format("{0:C}", Model.BudgetAmount)</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="MonthlyBudgetId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
